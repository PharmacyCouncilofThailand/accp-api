{
  "name": "accp-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');fs.mkdirSync('public/email',{recursive:true});fs.copyFileSync('src/assets/email/thanompong-signature.png','public/email/thanompong-signature.png');fs.cpSync('src/templates','dist/templates',{recursive:true});fs.cpSync('src/assets','dist/assets',{recursive:true})\"",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "npx tsx src/database/seed.ts",
    "db:migrate-sessions": "npx tsx src/database/migrate-sessions.ts",
    "db:import-schedule": "npx tsx src/scripts/import-presentation-schedule.ts"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/jwt": "^9.0.2",
    "@fastify/multipart": "^9.3.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "docxtemplater": "^3.68.6",
    "dotenv": "^16.4.7",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "googleapis": "^170.0.0",
    "libreoffice-convert": "^1.8.1",
    "pdfkit": "^0.17.2",
    "pizzip": "^3.2.0",
    "postgres": "^3.4.5",
    "puppeteer": "^24.37.5",
    "qrcode": "^1.5.4",
    "stripe": "^20.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.2",
    "@types/pdfkit": "^0.17.5",
    "@types/qrcode": "^1.5.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
